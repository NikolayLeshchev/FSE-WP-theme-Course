# 1. Игнорируем абсолютно всё в корне
/*

# 2. Исключаем (разрешаем) только нужные файлы
!/.gitignore
!/README.md
!/wp-content/

# 3. Внутри wp-content игнорируем всё
/wp-content/*

# 4. Разрешаем папки плагинов и тем (но не их содержимое пока что)
!/wp-content/plugins/
!/wp-content/themes/

# 5. Игнорируем все стандартные темы и плагины внутри
/wp-content/themes/*
/wp-content/plugins/*

# 6. РАЗРЕШАЕМ ТВОЮ ТЕМУ (вот тут магия)
!/wp-content/themes/udemy/

# 7. Игнорируем мусор разработки
node_modules/
dist/
.DS_Store
local-xdebuginfo.php