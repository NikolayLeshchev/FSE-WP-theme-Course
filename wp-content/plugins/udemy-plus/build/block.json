{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "udemy-plus/fancy-header",
  "title": "Fancy header",
  "category": "text",
  "icon": "star-filled",
  "description": "Add a header with a hover effect",
  "keywords": [
    "header",
    "underline",
    "hover"
  ],
  "version": "1",
  "textdomain": "udemy-plus",
  "editorScript": "file:/index.js",
  "attributes": {
    "content": {
      "type": "string"
    },
    "underline_color": {
      "type": "string",
      "default": "#f87171"
    }
  },
  "style": "file:./index.css"
}